// Zaneva AI Content Studio - Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id            String   @id @default(cuid())
  type          String   // "chatgpt" | "gemini"
  name          String
  email         String?
  sessionCookie String?  // encrypted at rest
  status        String   @default("active") // active | paused | error
  tokenStatus   String   @default("ready") // ready | exhausted | cooldown
  lastUsedAt    DateTime?
  usageCount    Int      @default(0)
  maxUsage      Int      @default(4)  // per-akun, bisa 3/4/5 tergantung limit Gemini
  resetAt       DateTime?              // auto-set dari error Gemini atau window expiry
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  generations   Generation[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  brandNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images      ProjectImage[]
  generations Generation[]
  storyboards Storyboard[]
}

model ProjectImage {
  id        String  @id @default(cuid())
  projectId String
  url       String  // local path or storage url
  filename  String
  order     Int     @default(0)
  createdAt DateTime @default(now())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Generation {
  id          String   @id @default(cuid())
  projectId   String
  accountId   String
  type        String   // "storyboard" | "video"
  prompt      String   @db.Text
  resultUrl   String?
  status      String   @default("pending") // pending | processing | completed | failed
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  account     Account  @relation(fields: [accountId], references: [id])
  storyboard  Storyboard? @relation(fields: [storyboardId], references: [id])
  storyboardId String?
}

model Storyboard {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  objective   String   @default("conversion")
  angle       String?
  pillars     String?
  notes       String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  generations Generation[]
}

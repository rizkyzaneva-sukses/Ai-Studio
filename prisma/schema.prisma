// Zaneva AI Content Studio - Database Schema
generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id            String   @id @default(cuid())
  type          String   // "chatgpt" | "gemini"
  name          String
  email         String?
  sessionCookie String?  // encrypted at rest
  status        String   @default("active") // active | paused | error
  lastUsedAt    DateTime?
  usageCount    Int      @default(0)
  maxUsage      Int      @default(50) // configurable limit per account
  resetAt       DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  generations   Generation[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  brandNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images      ProjectImage[]
  generations Generation[]
}

model ProjectImage {
  id        String  @id @default(cuid())
  projectId String
  url       String  // local path or storage url
  filename  String
  order     Int     @default(0)
  createdAt DateTime @default(now())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Generation {
  id          String   @id @default(cuid())
  projectId   String
  accountId   String
  type        String   // "storyboard" | "video"
  prompt      String   @db.Text
  resultUrl   String?
  status      String   @default("pending") // pending | processing | completed | failed
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  account     Account  @relation(fields: [accountId], references: [id])
}
